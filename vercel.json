{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/handler.ts": {
      "includeFiles": "public/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/handler" },
    { "source": "/checkout/:id", "destination": "/api/handler" },
    { "source": "/", "destination": "/api/handler" }
  ]
}
